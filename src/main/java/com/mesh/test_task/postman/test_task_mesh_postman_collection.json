    "description": "One-click прогон для auth + me emails/phones endpoint-ов на seed-данных из Liquibase.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestUrl = pm.request.url ? pm.request.url.toString() : '';",
          "const publicPaths = ['/v1/auth/login', '/v3/api-docs', '/swagger-ui', '/actuator/health'];",
          "const isPublicRequest = publicPaths.some(path => requestUrl.includes(path));",
          "const token = pm.collectionVariables.get('meshAccessToken');",
          "",
          "function isExpiredJwt(value) {",
          "  try {",
          "    const payload = JSON.parse(atob(value.split('.')[1]));",
          "    return payload.exp && Date.now() >= (payload.exp * 1000 - 5000);",
          "  } catch (e) {",
          "    return true;",
          "  }",
          "}",
          "",
          "if (!isPublicRequest && (!token || isExpiredJwt(token))) {",
          "  const baseUrl = pm.collectionVariables.get('meshBaseUrl');",
          "  const login = pm.collectionVariables.get('meshLogin');",
          "  const password = pm.collectionVariables.get('meshPassword');",
          "",
          "  pm.sendRequest({",
          "    url: `${baseUrl}/v1/auth/login`,",
          "    method: 'POST',",
          "    header: {",
          "      'Content-Type': 'application/json'",
          "    },",
          "    body: {",
          "      mode: 'raw',",
          "      raw: JSON.stringify({ login, password })",
          "    }",
          "  }, function (err, response) {",
          "    if (err) {",
          "      throw new Error(`Auto-login failed: ${err.message || err}`);",
          "    }",
          "    if (!response || response.code !== 200) {",
          "      throw new Error(`Auto-login failed with status ${response ? response.code : 'unknown'}`);",
          "    }",
          "",
          "    const json = response.json();",
          "    pm.collectionVariables.set('meshAccessToken', json.accessToken || '');",
          "  });",
          "}"
        ]
      }
    }
  ],
