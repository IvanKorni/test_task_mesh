{
  "info": {
    "name": "Test Task Mesh API Collection",
    "_postman_id": "9f4f3569-853d-43a5-8f6f-6a5a385f60f3",
    "description": "One-click прогон для auth + me emails/phones endpoint-ов на seed-данных из Liquibase.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "meshBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "meshLogin",
      "value": "ivan.petrov@example.com"
    },
    {
      "key": "meshPassword",
      "value": "password1"
    },
    {
      "key": "meshAccessToken",
      "value": ""
    },
    {
      "key": "meshEmailId",
      "value": ""
    },
    {
      "key": "meshPhoneId",
      "value": ""
    },
    {
      "key": "meshNewEmail",
      "value": ""
    },
    {
      "key": "meshUpdatedEmail",
      "value": ""
    },
    {
      "key": "meshNewPhone",
      "value": ""
    },
    {
      "key": "meshUpdatedPhone",
      "value": ""
    },
    {
      "key": "meshDuplicateEmail",
      "value": ""
    },
    {
      "key": "meshMissingEmailId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0) Setup variables",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const ts = Date.now();",
              "pm.collectionVariables.set('meshNewEmail', `mesh.new.${ts}@example.com`);",
              "pm.collectionVariables.set('meshUpdatedEmail', `mesh.updated.${ts}@example.com`);",
              "pm.collectionVariables.set('meshNewPhone', `79${String(ts).slice(-9)}`);",
              "pm.collectionVariables.set('meshUpdatedPhone', `78${String(ts).slice(-9)}`);",
              "pm.collectionVariables.set('meshMissingEmailId', String(900000000 + (ts % 1000000)));",
              "const login = pm.collectionVariables.get('meshLogin') || '';",
              "if (!pm.collectionVariables.get('meshDuplicateEmail') && login.includes('@')) {",
              "  pm.collectionVariables.set('meshDuplicateEmail', login);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Setup vars are prepared', function () {",
              "  pm.expect(pm.collectionVariables.get('meshNewEmail')).to.include('@');",
              "  pm.expect(pm.collectionVariables.get('meshUpdatedEmail')).to.include('@');",
              "  pm.expect(pm.collectionVariables.get('meshNewPhone')).to.match(/^\\d{11}$/);",
              "  pm.expect(pm.collectionVariables.get('meshUpdatedPhone')).to.match(/^\\d{11}$/);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{meshBaseUrl}}/actuator/health"
      }
    },
    {
      "name": "1) Login (POST /v1/auth/login)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('meshAccessToken', json.accessToken || '');",
              "pm.test('accessToken received', function () {",
              "  pm.expect(pm.collectionVariables.get('meshAccessToken')).to.not.equal('');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{meshLogin}}\",\n  \"password\": \"{{meshPassword}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/auth/login"
      }
    },
    {
      "name": "2) Add Email (POST /v1/me/emails)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('meshEmailId', String(json.id || ''));",
              "pm.test('emailId received', function () {",
              "  pm.expect(pm.collectionVariables.get('meshEmailId')).to.not.equal('');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{meshNewEmail}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/emails"
      }
    },
    {
      "name": "3) Update Email (PUT /v1/me/emails/{{meshEmailId}})",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Email updated', function () {",
              "  pm.expect(String(json.id)).to.equal(pm.collectionVariables.get('meshEmailId'));",
              "  pm.expect(json.email).to.equal(pm.collectionVariables.get('meshUpdatedEmail'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{meshUpdatedEmail}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/emails/{{meshEmailId}}"
      }
    },
    {
      "name": "4) Delete Email (DELETE /v1/me/emails/{{meshEmailId}})",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('204 No Content', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          }
        ],
        "url": "{{meshBaseUrl}}/v1/me/emails/{{meshEmailId}}"
      }
    },
    {
      "name": "5) Add Phone (POST /v1/me/phones)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('meshPhoneId', String(json.id || ''));",
              "pm.test('phoneId received', function () {",
              "  pm.expect(pm.collectionVariables.get('meshPhoneId')).to.not.equal('');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{meshNewPhone}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/phones"
      }
    },
    {
      "name": "6) Update Phone (PUT /v1/me/phones/{{meshPhoneId}})",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Phone updated', function () {",
              "  pm.expect(String(json.id)).to.equal(pm.collectionVariables.get('meshPhoneId'));",
              "  pm.expect(json.phone).to.equal(pm.collectionVariables.get('meshUpdatedPhone'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{meshUpdatedPhone}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/phones/{{meshPhoneId}}"
      }
    },
    {
      "name": "7) Delete Phone (DELETE /v1/me/phones/{{meshPhoneId}})",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('204 No Content', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          }
        ],
        "url": "{{meshBaseUrl}}/v1/me/phones/{{meshPhoneId}}"
      }
    },
    {
      "name": "8) Negative: /v1/me/emails without token -> 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{meshNewEmail}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/emails"
      }
    },
    {
      "name": "9) Negative: duplicate email -> error",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Duplicate email returns error', function () {",
              "  pm.expect(pm.response.code).to.be.at.least(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{meshDuplicateEmail}}\"\n}"
        },
        "url": "{{meshBaseUrl}}/v1/me/emails"
      }
    },
    {
      "name": "10) Negative: delete missing emailId -> error",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Missing email id returns error', function () {",
              "  pm.expect(pm.response.code).to.be.at.least(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{meshAccessToken}}"
          }
        ],
        "url": "{{meshBaseUrl}}/v1/me/emails/{{meshMissingEmailId}}"
      }
    }
  ]
}
