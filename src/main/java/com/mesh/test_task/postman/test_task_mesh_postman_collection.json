      "name": "11) Search Users by name/date/phone (GET /v1/users/search)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Search response has page metadata', function () {",
              "  pm.expect(json.items).to.be.an('array');",
              "  pm.expect(json.page).to.equal(0);",
              "  pm.expect(json.size).to.equal(20);",
              "  pm.expect(json.totalElements).to.be.at.least(1);",
              "});",
              "pm.test('Seed user is returned', function () {",
              "  const user = json.items.find(item => String(item.id) === pm.collectionVariables.get('meshSelfUserId'));",
              "  pm.expect(user).to.not.equal(undefined);",
              "  pm.expect(user.name).to.include(pm.collectionVariables.get('meshSearchName'));",
              "  pm.expect(user.dateOfBirth).to.equal(pm.collectionVariables.get('meshExpectedDateOfBirth'));",
              "  pm.expect(user.phones).to.include(pm.collectionVariables.get('meshSearchPhone'));",
              "});"
            ]
          }
        }
